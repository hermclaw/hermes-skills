def eta_minutes(arrival_dt: datetime, now: datetime) -> int | None:
    if arrival_dt is None:
        return None
    diff = (arrival_dt - now).total_seconds() / 60
    return int(diff) if diff >= 0 else None


def format_eta(minutes: int | None) -> str:
    if minutes is None:
        return "arriving"
    if minutes <= 0:
        return "now"
    if minutes == 1:
        return "1 min"
    return f"{minutes} min"


def format_lines(lines: list[str]) -> str:
    """Format line list like ['1','2','3'] into '1 / 2 / 3'"""
    return ' / '.join(lines)


def fetch_trains(line_ids: list[str], stop_id: str, now: datetime):
    """Get sorted list of (route, destination, arrival_dt) for trains at a stop."""
    all_trips = []
    for line in line_ids:
        try:
            feed = NYCTFeed(line)
            all_trips.extend(feed.filter_trips(line_id=[line], underway=True))
        except Exception:
            pass

    matching = []
    for t in all_trips:
        for stu in t.stop_time_updates:
            if stu.stop_id == stop_id:
                matching.append((t.route_id, t.headsign_text or "Unknown", stu.arrival))
                break

    # Sort by arrival
    def sort_key(x):
        m = eta_minutes(x[2], now)
        return (m is None, m if m is not None else 0)

    matching.sort(key=sort_key)
    return matching


def find_station(query: str) -> tuple[str, str, list[str]] | None:
    """Find station by name (case-insensitive partial match)."""
    query = query.lower().strip()

    # Exact match
    if query in STATIONS:
        return STATIONS[query]

    # Partial match
    matches = [(name, data) for name, data in STATIONS.items() if query in name]

    if len(matches) == 1:
        return matches[0][1]
    elif len(matches) > 1:
        print(f"Multiple matches for '{query}':", file=sys.stderr)
        for name, _ in matches:
            print(f"  - {name}", file=sys.stderr)
        return None

    return None


def list_stations():
    """List all available stations."""
    print("Available stations:", file=sys.stderr)
    for name in sorted(STATIONS.keys()):
        _, _, lines = STATIONS[name]
        print(f"  - {name} ({format_lines(lines)})", file=sys.stderr)


def main():
    parser = argparse.ArgumentParser(
        description="NYC subway train report — real-time ETA for a station (both directions).",
        epilog="Example: train-report 'Hoyt St' or train-report '34 St-Penn Station'"
    )
    parser.add_argument(
        "station",
        nargs="?",
        help="Station name (e.g., 'Hoyt St', '34 St-Penn Station', 'Penn Station')"
    )
    parser.add_argument(
        "--list", "-l",
        action="store_true",
        help="List all available stations"
    )
    args = parser.parse_args()

    if args.list:
        list_stations()
        sys.exit(0)

    if not args.station:
        print("Error: Please provide a station name.", file=sys.stderr)
        print("\nUsage: train-report 'Station Name'", file=sys.stderr)
        print("       train-report --list  # to see all stations", file=sys.stderr)
        sys.exit(1)

    station_data = find_station(args.station)

    if not station_data:
        print(f"Error: Unknown station '{args.station}'", file=sys.stderr)
        print("\nUse --list to see available stations.", file=sys.stderr)
        sys.exit(1)

    north_id, south_id, lines = station_data

    now = datetime.now()
    print(f"\n🕐  {now.strftime('%I:%M %p')} — {args.station.title()}")
    print("═" * 50)

    # Northbound
    trains_n = fetch_trains(lines, north_id, now)
    print(f"\n⬆️  Uptown / Northbound")
    print(f"   ({format_lines(lines)})")
    if trains_n:
        for route, dest, arr_dt in trains_n:
            mins = eta_minutes(arr_dt, now)
            eta = format_eta(mins)
            time_str = arr_dt.strftime("%I:%M") if arr_dt else "?"
            print(f"   {route} → {dest:<30} [{eta:>7}]  {time_str}")
    else:
        print("   no trains")

    # Southbound
    trains_s = fetch_trains(lines, south_id, now)
    print(f"\n⬇️  Downtown / Southbound")
    print(f"   ({format_lines(lines)})")
    if trains_s:
        for route, dest, arr_dt in trains_s:
            mins = eta_minutes(arr_dt, now)
            eta = format_eta(mins)
            time_str = arr_dt.strftime("%I:%M") if arr_dt else "?"
            print(f"   {route} → {dest:<30} [{eta:>7}]  {time_str}")
    else:
        print("   no trains")

    print()


if __name__ == "__main__":
    main()
